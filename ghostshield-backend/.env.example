# GhostShield AI - Environment Configuration Template
# Copy this to .env and fill in your values

# ==================== Environment ====================
ENVIRONMENT=development
DEBUG=False

# ==================== Database ====================
# Local: postgresql://user:password@localhost/ghostshield_db
# Render: Provided in dashboard (DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost/ghostshield_db

# ==================== API Configuration ====================
API_TITLE="GhostShield AI API"
API_VERSION=1.0.0

# ==================== Security ====================
# Change this to a random string in production
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ==================== AI/ML Settings ====================
# Face verification threshold (0-1, higher = more strict)
FACE_MATCH_THRESHOLD=0.6

# Anomaly detection threshold (0-1, higher = more suspicious)
ANOMALY_THRESHOLD=0.7

# Risk score approval threshold (0-100, lower = stricter)
RISK_SCORE_APPROVAL_THRESHOLD=70

# ==================== Squad API ====================
# Get these from Squad dashboard (https://dashboard.squadco.com)
SQUAD_API_KEY=your-squad-api-key
SQUAD_PUBLIC_KEY=your-squad-public-key
SQUAD_API_BASE_URL=https://api.squadco.com
SQUAD_WEBHOOK_SECRET=your-squad-webhook-secret

# ==================== File Storage ====================
# Local path for MVP (change to S3 in production)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ==================== Feature Flags ====================
ENABLE_FACE_VERIFICATION=True
ENABLE_ANOMALY_DETECTION=True
ENABLE_SQUAD_INTEGRATION=True

# ==================== Deployment ====================
# Render: Set these in the dashboard
# Development: Use defaults below
PORT=8000
HOST=0.0.0.0
